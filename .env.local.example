# ImageKit credentials
# Get these from imagekit.io → Developer Options
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Secret upload path — change this to something hard to guess
# Your upload page will be at /upload/YOUR_SECRET_KEY
UPLOAD_SECRET=change-this-to-something-secret-123
